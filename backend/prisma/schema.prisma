generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["community", "app_auth"]
}

enum PostStatus {
  free_board
  community_confirmed
  admin_verified
  rejected
  resolved
  expired

  @@map("post_status")
  @@schema("community")
}

enum ReactionType {
  confirm
  useful
  fake
  resolved

  @@map("reaction_type")
  @@schema("community")
}

enum NotificationType {
  community_confirmed
  admin_verified
  rejected
  resolved
  expired
  post_reaction

  @@map("notification_type")
  @@schema("community")
}

/// Shared CoreMap auth user. Source of truth: app_auth.auth_users.
/// This backend reuses the same accounts, password hashes, and roles as CoreMap.
model AuthUser {
  id                BigInt    @id @default(autoincrement())
  publicId          String    @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  email             String    @unique
  passwordHash      String    @map("password_hash")
  displayName       String    @map("display_name")
  isActive          Boolean   @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  phone             String?
  emailVerified     Boolean   @default(false) @map("email_verified")
  accountStatus     String    @default("active") @map("account_status")
  primaryRegionId   BigInt?   @map("primary_region_id")
  preferredLanguage String    @default("my") @map("preferred_language")
  lastSeenAt        DateTime? @map("last_seen_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)
  adminNote         String?   @map("admin_note")

  userRoles          AuthUserRole[]
  sessions           AuthSession[]
  posts              CommunityPost[]
  reactions          PostReaction[]
  notifications      Notification[] @relation("NotificationRecipient")
  notificationsActed Notification[] @relation("NotificationActor")

  @@map("auth_users")
  @@schema("app_auth")
}

model AuthRole {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique
  name        String   @unique
  description String?
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles AuthUserRole[]

  @@map("auth_roles")
  @@schema("app_auth")
}

model AuthUserRole {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  roleId     BigInt   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AuthRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("auth_user_roles")
  @@schema("app_auth")
}

model AuthSession {
  id               BigInt    @id @default(autoincrement())
  publicId         String    @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  userId           BigInt    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
  @@schema("app_auth")
}

model CommunityPost {
  id          BigInt     @id @default(autoincrement())
  publicId    String     @unique @default(uuid()) @map("public_id") @db.Uuid
  authorId    BigInt     @map("author_id")
  title       String
  description String
  topic       String
  status      PostStatus @default(free_board)
  trustScore  Int        @default(0) @map("trust_score")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  author        AuthUser       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  reactions     PostReaction[]
  notifications Notification[]

  @@index([authorId])
  @@index([status])
  @@map("community_posts")
  @@schema("community")
}

model Notification {
  id            BigInt           @id @default(autoincrement())
  publicId      String           @unique @default(uuid()) @map("public_id") @db.Uuid
  userId        BigInt           @map("user_id")
  actorUserId   BigInt?          @map("actor_user_id")
  type          NotificationType
  reactionType  ReactionType?    @map("reaction_type")
  title         String
  message       String
  relatedPostId BigInt?          @map("related_post_id")
  isRead        Boolean          @default(false) @map("is_read")
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  user        AuthUser       @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor       AuthUser?      @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  relatedPost CommunityPost? @relation(fields: [relatedPostId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([actorUserId])
  @@index([isRead])
  @@index([relatedPostId])
  @@map("notifications")
  @@schema("community")
}

model PostReaction {
  id           BigInt       @id @default(autoincrement())
  postId       BigInt       @map("post_id")
  userId       BigInt       @map("user_id")
  reactionType ReactionType @map("reaction_type")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user AuthUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_reactions")
  @@schema("community")
}
