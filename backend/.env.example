PORT=3000
NODE_ENV=development

# Existing CoreMap / Supabase PostgreSQL (must already include app_auth)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/community_info_news?schema=public

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-in-production

# Optional comma-separated browser origins (e.g. http://localhost:5173)
# Leave unset to allow all origins (dev default).
# CORS_ORIGIN=http://localhost:5173

# Demo Mode (classroom / showcase). When "true", the /demo/* routes and the
# frontend Demo toolbar are enabled. Demo login still issues real JWTs and
# Demo Admin still requires the admin role — there is no AUTH_BYPASS.
# WARNING: never enable DEMO_MODE on a real production deployment; showcase
# demos may set DEMO_MODE=true intentionally, then turn it off afterwards.
DEMO_MODE=false

# Rate limits (max requests per time window in ms)
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW_MS=60000
RATE_LIMIT_CREATE_POST_MAX=20
RATE_LIMIT_CREATE_POST_WINDOW_MS=60000
RATE_LIMIT_REACTIONS_MAX=30
RATE_LIMIT_REACTIONS_WINDOW_MS=60000
