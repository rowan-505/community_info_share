# Docker environment for the backend container.
# Copy to .env in the project root before running: docker compose up --build
#
# DATABASE_URL must point at an existing CoreMap/Supabase PostgreSQL database
# that already has the shared app_auth schema (auth_users, auth_roles, …).
# A fresh empty Postgres database will not work with this project's migrations.

PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
JWT_SECRET=change-me-in-production

# Showcase only. Keep false for real production.
DEMO_MODE=false

# Optional comma-separated browser origins (e.g. http://localhost:5173)
# Leave empty to allow all origins (dev default).
CORS_ORIGIN=
